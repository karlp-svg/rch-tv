# ==========================================
#  RCH TV - Environment Variables
# ==========================================

# PostgreSQL connection (Supabase URI in production)
# Local example:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# ---- Cloudflare R2 Photo Storage ----
# Photos are stored in R2 (zero egress), not in the DB.
# Get these from Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=rch-tv-photos
R2_PUBLIC_URL=

# ---- DJ Console authentication ----
# If DJ_CONSOLE_PASSWORD is set, the DJ Console and admin APIs are protected with HTTP Basic Auth.
# Browser username defaults to 'dj' unless you set DJ_CONSOLE_USERNAME.
DJ_CONSOLE_USERNAME=dj
DJ_CONSOLE_PASSWORD=

# ---- Public app URL ----
# Set this on the DJ deployment so QR/session links point to the public user app.
# Example: https://rch-tv.vercel.app
NEXT_PUBLIC_PUBLIC_APP_URL=

# ---- Deployment mode ----
# Set this to 'true' on all three Vercel projects to hide the sandbox navigation bar.
# Leave blank (or unset) in local/preview environments to keep it visible for testing.
NEXT_PUBLIC_PRODUCTION_MODE=
